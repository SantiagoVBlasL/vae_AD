# Python
__pycache__/
*.py[cod]
*.so
*.pyd
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
logs/
wandb/
mlruns/

# Results / artifacts (do not version generated outputs)
results/**
!results/README.md
!results/.gitkeep

# Data (ignore heavy tensors / derived binaries, keep lightweight tabular metadata)
data/**
!data/README.md
!data/.gitkeep
!data/*.csv
!data/*.tsv
!data/*.txt
!data/*.json
!data/*.yml
!data/*.yaml

# Big binaries common in ML / neuroimaging
*.pt
*.pth
*.ckpt
*.onnx
*.npz
*.npy
*.pkl
*.joblib
*.h5
*.hdf5
*.nii
*.nii.gz

# Backup files
*.bak

# Local artifacts
artifacts/

# Exported notebooks
notebooks/*.html

# Generated plots in notebooks root
notebooks/betavae_*.png

# Ablation intermediate outputs
notebooks/ablation_full_run_fast/**
!notebooks/ablation_full_run_fast/summary_ablation.csv
!notebooks/ablation_full_run_fast/summary_ablation.json

# Uncomment ONLY if the .ipynb is the sole source of truth
# notebooks/*.py

# Virtual environments
.venv/
.codex_tmp/

notebooks/archive/
